# Copy to ".env" and fill in. All values are optional for the core savings app;
# Plaid values are only needed for real bank linking.

# --- Plaid (free sandbox keys at https://dashboard.plaid.com) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# 32-byte key used to encrypt Plaid access tokens at rest.
# Generate one with:  openssl rand -base64 32
PLAID_TOKEN_KEY=

# --- Cookies ---
# Leave blank for local HTTP. Set to "production" only when served over HTTPS
# (enables the Secure flag on the session cookie).
APP_ENV=
